# Copy this file to .env and fill in your values.
# The launchd plist sets these as EnvironmentVariables — .env is for local dev.

# ── LLM ──────────────────────────────────────────────────────────────────────
# DeepSeek API key (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sk-...

# ── Obsidian Vault ────────────────────────────────────────────────────────────
# Full path to your Obsidian vault root (used by the Node.js hook)
ATLAS_OBSIDIAN_VAULT=/Volumes/your-drive/obsidian-vault

# ── Local services (defaults work if you follow the setup guide) ──────────────
# Qdrant:  http://127.0.0.1:6333
# Ollama:  http://127.0.0.1:11434
# oMLX:    http://127.0.0.1:7749   (optional — faster local inference on Apple Silicon)
